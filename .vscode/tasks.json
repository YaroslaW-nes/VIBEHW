{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Requirements",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Streamlit App",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "streamlit",
        "run",
        "app.py",
        "--server.address=127.0.0.1",
        "--server.port=8501"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Install Requirements",
      "isBackground": true,
      "problemMatcher": {
        "owner": "streamlit",
        "pattern": [
          {
            "regexp": "."
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*streamlit run.*|.*Collecting usage statistics.*",
          "endsPattern": ".*URL: http://127\\.0\\.0\\.1:8501.*|.*Network URL:.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
